generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id                Int            @id @default(autoincrement())
  email             String?
  phoneNumber       String?
  linkedId          Int?
  linkPrecedence    LinkPrecedence
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  deletedAt         DateTime?
  // self relation
  primaryContact    Contact?       @relation("ContactToPrimary", fields: [linkedId], references: [id])
  secondaryContacts Contact[]      @relation("ContactToPrimary")

  // uhh for the primaryContact the linkedId = null and linkPrecendence is Primary
  // it means the row Primary -> linkedId = null
  // now one primaryContact can have many secondaryContact but one secondaryContact point to one primaryContact 
  // now row secondaryContact -> linkedId = some id 

  // when we build the primaryContact id = 1 , linkedId = null linkPre = Primary 
  // when we build the secondaryContaact id = 23 linkedId = 1 linkPre = secondary 

  @@index([email])
  @@index([phoneNumber])
  @@index([linkedId])
}

enum LinkPrecedence {
  primary
  secondary
}

